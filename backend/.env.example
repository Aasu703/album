PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/painting_gallery

# JWT — access token intentionally long-lived per module requirement (>=15 days).
# See README security notes for the tradeoff this implies.
JWT_ACCESS_SECRET=replace_with_a_long_random_string_at_least_32_chars
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string_32_chars
JWT_ACCESS_TTL=15d
JWT_REFRESH_TTL=30d

# Cloudinary (image storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CORS allowlist (also used as the post-OAuth redirect target)
FRONTEND_ORIGIN=http://localhost:3000

# SameSite attribute for the auth cookies. Keep 'lax': 'strict' breaks Google login, because
# browsers withhold Strict cookies from the post-OAuth navigation and the edge guard in
# proxy.ts then bounces the freshly signed-in user back to /login.
COOKIE_SAMESITE=lax

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# The callback URL must be registered as an "Authorized redirect URI" on the OAuth client.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# SMTP (password-reset email). Leave blank in dev — reset codes are logged to the console.
# Example for Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_SECURE=true, SMTP_USER=you@gmail.com, SMTP_PASS=<app password>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Painting Gallery <no-reply@gallery.test>
