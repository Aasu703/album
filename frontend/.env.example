# NestJS backend base URL (no trailing slash, no /api suffix)
BACKEND_URL=http://localhost:4000

# Public app URL used for links
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# Recommended dedicated session secret (32+ random bytes).
SESSION_SECRET=replace_with_a_secure_random_string

# Optional comma-separated allowlist for browser-originated mutating requests.
# Example: https://your-domain.com,https://www.your-domain.com
ALLOWED_ORIGINS=

# Admin panel password (required for /admin and /api/admin routes)
ADMIN_PASSWORD=your_chosen_password_here
