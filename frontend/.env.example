# Public NestJS backend base URL, browser-reachable, including the /api prefix
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Stripe publishable key (safe for the browser) - must match the backend's STRIPE_SECRET_KEY account
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# Public app URL used for links
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# Admin panel password (reserved for the admin panel rebuild)
ADMIN_PASSWORD=your_chosen_password_here
